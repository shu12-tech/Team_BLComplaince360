    <bpmn:textAnnotation id="anno_start">
      <bpmn:text>Runs on a scheduled interval (e.g., every 24hrs) or triggered on-demand via webhook</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="anno_collect_fabric">
      <bpmn:text>Queries internal DB registries and WebAPP for processing records</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="anno_collect_docs">
      <bpmn:text>Uses UiPath Document Understanding to extract data from PDFs, contracts &amp; audit reports</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="anno_review_findings">
      <bpmn:text>Maestro pauses thread; Officer reviews via UiPath Action Center</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_UwTilb">
      <bpmn:text>LangChain / UiPath Agent Builder evaluates controls and scores 0–100%</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_RfM9y6">
      <bpmn:text>AI recommends remediation based on
risk score, failed controls and policy rules.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_fjtf7a">
      <bpmn:text>Critical findings are escalated for
executive approval before remediation.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_jJPlAN">
      <bpmn:text>Robot executes predefined remediation</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_LKrHKW">
      <bpmn:text>Agent verifies whether remediation resolved the control failure using updated evidence.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_XhUrZX">
      <bpmn:text>Evidence Collector merges all available evidence. Unavailable sources are logged and assessment continues with partial evidence.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Text_ZnKScu">
      <bpmn:text>Generates auditor-ready HTML evidence package containing:
• Findings
• Evidence
• Remediation
• Validation Results
• Audit Readiness Score</bpmn:text>
    </bpmn:textAnnotation>
  </bpmn:process>
